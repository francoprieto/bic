{
  "name": "bic-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "build-fat-win64": "node ./tooling.js fat win64 && electron-builder --win --x64",
    "build-slim-win64": "node ./tooling.js slim win64 && electron-builder --win --x64",
    "build-fat-mac-arm64": "node ./tooling.js fat mac-arm64 && electron-builder --mac --arm64",
    "build-slim-mac-arm64": "node ./tooling.js slim mac-arm64 && electron-builder --mac --arm64",
    "build-fat-linux-x64": "node ./tooling.js fat linux-x64 && electron-builder --linux --x64",
    "build-slim-linux-x64": "node ./tooling.js slim linux-x64 && electron-builder --linux --x64"
  },
  "keywords": [],
  "author": {
    "name": "Firmador BIC",
    "email": "info@francoprieto.com"
  },
  "license": "ISC",
  "description": "Aplicación de firma digital BIC",
  "homepage": "https://francoprieto.com",
  "dependencies": {
    "form-data": "^4.0.4",
    "npx": "^10.2.2",
    "pako": "^2.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "electron": "^37.2.4",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "py.org.firmador.bic",
    "productName": "Bic",
    "icon": "assets/icon.png",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!extraResources/**"
    ],
    "extraResources": [
      {
        "from": "./extraResources",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      }
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "maintainer": "Firmador BIC <info@firmador.org>",
      "mimeTypes": [
        "x-scheme-handler/bic"
      ],
      "desktop": {
        "MimeType": "x-scheme-handler/bic"
      },
      "afterInstall": "build/postinst"
    }
  }
}
